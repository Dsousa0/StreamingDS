# Banco de Dados
MONGO_URI=mongodb://localhost:27017/streamingds

# Autenticação JWT
JWT_SECRET=sua-chave-jwt-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=24h

# Criptografia das senhas dos streamers
SECRET_KEY=sua-chave-criptografia-32chars

# TMDB API
TMDB_KEY=sua-chave-tmdb-aqui

# Servidor
PORT=3001
NODE_ENV=development

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173

# Usuário de acesso à plataforma local
PLATFORM_USER=admin

# Senha de acesso à plataforma local
PLATFORM_PASSWORD=minha-senha-local
