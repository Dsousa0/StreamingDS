# ─── Banco de Dados ─────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/streamingds
# Docker: sobrescrito automaticamente para mongodb://mongo:27017/streamingds
MONGO_URI=mongodb://localhost:27017/streamingds

# ─── Autenticação JWT ────────────────────────────────────────────────────────
JWT_SECRET=sua-chave-jwt-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=24h

# ─── Criptografia das senhas dos streamers ───────────────────────────────────
SECRET_KEY=sua-chave-criptografia-32chars

# ─── TMDB API ────────────────────────────────────────────────────────────────
TMDB_KEY=sua-chave-tmdb-aqui

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Desenvolvimento: http://localhost:5173
# Docker local:    http://localhost
# VPS:             https://seu-dominio.com
ALLOWED_ORIGINS=http://localhost:5173

# ─── Usuário admin inicial (seed na primeira execução) ───────────────────────
PLATFORM_USER=admin
PLATFORM_PASSWORD=minha-senha-local

# ─── Docker (opcional) ───────────────────────────────────────────────────────
# Porta exposta pelo container do frontend (padrão: 80)
APP_PORT=80
