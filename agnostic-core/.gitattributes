# Line endings
* text=auto eol=lf
*.md text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary

# Archive ignores (shrink git archive / npm tarball)
.github/ export-ignore
.editorconfig export-ignore
.gitattributes export-ignore
.markdownlint.json export-ignore
